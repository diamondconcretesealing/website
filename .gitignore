# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local secrets (one-time migration token; never commit)
scripts/.sanity-token

# browser-verification artifacts (root-level screenshots + Playwright output)
/.playwright-mcp/
/reviews-section*.png

# local agent/tooling config
/.claude/
/CLAUDE.md

# raw customer photo originals (multi-MB) — resized copies live in public/images/
/Customer Photos/

# unused source media — not referenced in code or shipped to the browser; kept
# out of clone/CI weight.
/clips/
/reference/

# scratch artifacts (phone photos + email previews)
/IMG_*.jpg
/IMG_*.jpeg
/IMG_*.png
/lead-email-preview.html
